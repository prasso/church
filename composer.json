{
    "name": "prasso/church",
    "description": "Comprehensive church management system for Laravel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "prasso/messaging": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Prasso\\Church\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Prasso\\Church\\ChurchServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
